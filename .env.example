# ============================================================================
#  .env.example  — copy to .env.local (gitignored) and fill in real values.
#  Real production values live ONLY in Vercel → Project → Environment Variables.
#  RULE: NEXT_PUBLIC_* is shipped to the browser and is PUBLIC forever.
#        Everything else is SERVER-ONLY and must never appear in client code.
# ============================================================================

# ---------- Public (safe in browser) ----------
NEXT_PUBLIC_SITE_URL=https://example.com
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon-key...     # anon key, RLS-restricted
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...      # publishable, not secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_...            # key id, not the secret
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAA...            # Cloudflare Turnstile site key

# ---------- SERVER ONLY — never NEXT_PUBLIC, never in client components ----------
SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role...     # bypasses RLS — guard with life
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...
RESEND_API_KEY=re_...

# Cloudflare R2 (S3-compatible) — server only
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_PUBLIC_BUCKET=invites-public          # free backgrounds, previews
R2_PRIVATE_BUCKET=invites-private        # premium masters + rendered outputs
R2_PUBLIC_BASE_URL=https://cdn.example.com   # Cloudflare-fronted public bucket

# Upstash Redis (rate limiting) — server only
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# Cloudflare Turnstile (anti-bot on checkout) — server only
TURNSTILE_SECRET_KEY=0x4AAA...

# Protects /api/cron/* (Vercel Cron sends it as `Authorization: Bearer <CRON_SECRET>`)
CRON_SECRET=generate-a-long-random-string

# Admin allowlist (comma-separated emails) — server only
ADMIN_EMAILS=founder@bitdrafter.com
